# ----------------------
# 1. Python & VS Code (The Basics)
# ----------------------
__pycache__/
*.pyc
.vscode/

# Catch all virtual environments, regardless of OS suffixes or dot prefixes
venv*/
.venv*/
env*/
.env*/

*.log

# ----------------------
# 2. Operating System Junk
# ----------------------
# Mac
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.Trash-*
.fuse_hidden*
.directory

# ----------------------
# 3. Autodesk Fusion Specifics
# ----------------------
*.manifest.bak
*.lock

# ----------------------
# 4. Installer & Build Output (CRITICAL)
# ----------------------
Output/
build/
dist/

# ----------------------
# 5. Security & Local Settings
# ----------------------
.env
.env.*
!.env.example

# ----------------------
# 6. Other Misc Files
# ----------------------
*.af
Archive/
artistly_images/
!Installers/
Installers/*.exe
Installers/*.msi
Installers/*.pkg
Installers/*.dmg
Installers/*.zip
Installers/*.wixpdb
Installers/Output/
*.exe
*.msi
*.pkg
*.dmg
*.zip

